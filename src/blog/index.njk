---
layout: layouts/base.njk
title: "Blog kiến thức đầu tư"
permalink: "/blog/"
---
<h1 class="blog-page-title">Blog kiến thức đầu tư</h1>

<style>
  .postcard-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 28px;
  }
  .postcard {
    display: flex;
    flex-direction: column;
    background: var(--gray-900, #0a0a0a);
    border: 1px solid var(--gray-700, #222);
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform .25s ease, border-color .25s ease;
  }
  .postcard:hover {
    transform: translateY(-4px);
    border-color: var(--green, #00c853);
  }
  .postcard-thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: linear-gradient(135deg, var(--gray-800, #151515), #050505);
    overflow: hidden;
  }
  .postcard-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .postcard-thumb .postcard-thumb-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 40px;
  }
  .postcard-tag {
    position: absolute;
    top: 12px;
    left: 12px;
    background: var(--green, #00c853);
    color: #000;
    font-size: 11px;
    font-weight: 700;
    padding: 5px 12px;
    border-radius: 999px;
    letter-spacing: .3px;
  }
  .postcard-body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .postcard-date {
    font-size: 12px;
    color: var(--gray-400, #888);
    margin-bottom: 8px;
  }
  .postcard-title {
    font-size: 17px;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 10px;
    color: var(--white, #fff);
  }
  .postcard-excerpt {
    font-size: 13.5px;
    color: var(--gray-300, #aaa);
    line-height: 1.6;
    margin-bottom: 16px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .postcard-footer {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .postcard-author {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12.5px;
    color: var(--gray-300, #aaa);
  }
  .postcard-avatar {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--green, #00c853);
    color: #000;
    font-size: 11px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .postcard-more {
    font-size: 13px;
    font-weight: 600;
    color: var(--green, #00c853);
  }
</style>

<div class="postcard-grid">
  {% for post in collections.posts | reverse %}
  <a href="{{ post.url | url }}" class="postcard fade-in">
    <div class="postcard-thumb">
      {% if post.data.cover %}
        <img src="{{ post.data.cover | url }}" alt="{{ post.data.title }}">
      {% else %}
        <div class="postcard-thumb-fallback">📊</div>
      {% endif %}
      {% if post.data.tags %}
        {% for tag in post.data.tags %}
          {% if tag != "posts" %}<span class="postcard-tag">{{ tag }}</span>{% endif %}
        {% endfor %}
      {% endif %}
    </div>
    <div class="postcard-body">
      <div class="postcard-date">{{ post.data.date | vnDate }}</div>
      <div class="postcard-title">{{ post.data.title }}</div>
      <div class="postcard-excerpt">{{ post.data.excerpt }}</div>
      <div class="postcard-footer">
        <div class="postcard-author">
          <span class="postcard-avatar">{{ post.data.author | default("OnTrend") | first }}</span>
          <span>{{ post.data.author | default("OnTrend") }}</span>
        </div>
        <div class="postcard-more">Đọc tiếp →</div>
      </div>
    </div>
  </a>
  {% endfor %}
</div>

<script>
  document.querySelectorAll('.postcard-grid .fade-in').forEach(function(el) {
    el.classList.add('visible');
  });
</script>
