---
layout: layouts/base.njk
---
<a href="/blog/" class="blog-back-link">← Tất cả bài viết</a>

<article class="post-header">
  <h1 class="post-title">{{ title }}</h1>
  <div class="post-meta">
    <span>{{ date | vnDate }}</span>
    {% if tags %}<span>{{ tags | join(", ") }}</span>{% endif %}
  </div>
</article>

{% if cover %}
<img src="{{ cover }}" alt="{{ title }}" class="post-cover">
{% endif %}

<div class="post-body">
  {{ content | safe }}
</div>
