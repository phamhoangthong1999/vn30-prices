---
layout: layouts/base.njk
---
<a href="{{ '/blog/' | url }}" class="blog-back-link">← Tất cả bài viết</a>
<article class="post-header">
  <h1 class="post-title">{{ title }}</h1>
  <div class="post-author" style="display:flex;align-items:center;gap:10px;margin:14px 0">
    <span style="width:32px;height:32px;border-radius:50%;background:var(--green,#00c853);color:#000;font-size:13px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0">{{ author | default("OnTrend") | first }}</span>
    <span style="font-size:14px;color:var(--gray-300,#aaa)">{{ author | default("OnTrend") }}</span>
  </div>
  <div class="post-meta">
    <span>{{ date | vnDate }}</span>
    {% if tags %}
      <span>
        {%- for tag in tags -%}
          {%- if tag != "posts" -%}{{ tag }}{% if not loop.last %}, {% endif %}{%- endif -%}
        {%- endfor -%}
      </span>
    {% endif %}
  </div>
</article>
{% if cover %}
<img src="{{ cover | url }}" alt="{{ title }}" class="post-cover">
{% endif %}
<div class="post-body">
  {{ content | safe }}
</div>
